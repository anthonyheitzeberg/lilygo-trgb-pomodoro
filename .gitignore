# ── ESP-IDF Build Artifacts ───────────────────────────────────────────────
build/                  # entire build output — regenerated by idf.py build
sdkconfig               # generated by menuconfig/set-target, machine-specific
sdkconfig.old           # backup of previous sdkconfig

# ── Dependencies ──────────────────────────────────────────────────────────
managed_components/     # IDF component manager downloads (like node_modules)

# ── VS Code ───────────────────────────────────────────────────────────────
.vscode/                # optional — some teams commit this, some don't
                        # if you want IntelliSense config shared, keep it
                        # if each dev generates their own, ignore it

# ── macOS ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ── Logs & Debug ──────────────────────────────────────────────────────────
*.log
*.map                   # linker map files

# ── Flash & Partition Artifacts ───────────────────────────────────────────
*.bin                   # compiled binaries (in build/ anyway, but just in case)
*.elf